{
  "name": "navia-x-desktop",
  "version": "0.1.0",
  "private": true,
  "author": "Navia-X Team",
  "description": "Windows-first floating desktop explainer for LLM text understanding.",
  "main": "src/main.js",
  "scripts": {
    "dev": "electron .",
    "start": "electron .",
    "dist:win": "electron-builder --win nsis"
  },
  "build": {
    "appId": "ai.naviax.explainer",
    "productName": "Navia-X Explainer",
    "directories": {
      "buildResources": "assets"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "devDependencies": {
    "electron": "33.2.1",
    "electron-builder": "25.1.8"
  }
}
