{
  "manifest_version": 3,
  "name": "Navia-X LLM Explainer",
  "version": "0.1.0",
  "description": "Select words on any webpage, confirm, and explain them with a floating glass explainer.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "http://localhost:8001/*",
    "http://127.0.0.1:8001/*"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Navia-X Explainer",
    "default_popup": "src/popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.js"],
      "css": ["src/content.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/navia-x.svg"],
      "matches": ["<all_urls>"]
    }
  ]
}
